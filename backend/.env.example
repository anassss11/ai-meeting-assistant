# NVIDIA Qwen 3.5 Configuration
# This file documents all available environment variables for NVIDIA Qwen 3.5 integration.
# Copy this file to .env and customize values for your deployment environment.

# NVIDIA API Configuration
# Your NVIDIA API key for accessing Qwen 3.5 model
# Required: Get from https://build.nvidia.com/
# Example: nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY=your_nvidia_api_key_here

# NVIDIA Model Configuration
# Specifies which NVIDIA model to use
# Default: "qwen/qwen3.5-397b-a17b"
# This is the Qwen 3.5 397B model optimized for instruction following
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b

# Response Length Configuration
# Maximum number of tokens in NVIDIA response
# Typical range: 1000-16384 tokens
# Default: 16384
# Increase for more detailed summaries, decrease for shorter summaries
NVIDIA_MAX_TOKENS=16384

# Temperature Configuration
# Controls randomness in NVIDIA responses
# Range: 0.0 (deterministic) to 2.0 (very creative)
# Default: 0.60
# Lower values (0.1-0.3) for consistent summaries, higher for creative responses
NVIDIA_TEMPERATURE=0.60

# Sampling Configuration
# Top-p sampling parameter (nucleus sampling)
# Range: 0.0 to 1.0
# Default: 0.95
# Controls diversity of token selection
NVIDIA_TOP_P=0.95

# Top-k sampling parameter
# Range: 1 to 100+
# Default: 20
# Limits token selection to top k most likely tokens
NVIDIA_TOP_K=20

# Penalty Configuration
# Presence penalty to reduce repetition
# Range: -2.0 to 2.0
# Default: 0.0
NVIDIA_PRESENCE_PENALTY=0.0

# Repetition penalty to reduce repetition
# Range: 0.0 to 2.0
# Default: 1.0
NVIDIA_REPETITION_PENALTY=1.0

# Fallback Configuration
# Enable automatic fallback to regex-based summarization when NVIDIA fails
# Valid values: "true" or "false"
# Default: "true"
# Set to "false" to propagate NVIDIA errors as HTTP 503 responses
NVIDIA_ENABLE_FALLBACK=true

# Input Length Configuration
# Maximum length of meeting transcript in characters
# Default: 50000
# NVIDIA Qwen 3.5 can handle very long inputs efficiently
NVIDIA_MAX_TRANSCRIPT_CHARS=50000

# Request Timeout Configuration
# Maximum time in seconds to wait for NVIDIA response
# Default: 0 (no timeout)
# Set to 0 for no timeout, allowing NVIDIA to take as long as needed
# Set to positive number (e.g., 60) to limit request time
NVIDIA_REQUEST_TIMEOUT=0

# Retry Configuration
# Maximum number of retry attempts for failed NVIDIA API calls
# Default: 3
# Helps handle temporary network or API issues
NVIDIA_MAX_RETRIES=3

# Advanced Configuration
# Enable thinking mode for better reasoning
# Valid values: "true" or "false"
# Default: "true"
# Enables chain-of-thought reasoning for better analysis
NVIDIA_ENABLE_THINKING=true