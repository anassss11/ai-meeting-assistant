# LLaMA 3 Configuration via Ollama
# This file documents all available environment variables for LLaMA 3 integration.
# Copy this file to .env and customize values for your deployment environment.

# LLaMA Model Configuration
# Specifies which LLaMA model to use via Ollama
# Valid values: "llama3", "llama3:8b", "llama3:70b", "llama3.1", "llama3.1:8b", "llama3.1:70b"
# Default: "llama3"
# Use "llama3:8b" for faster responses, "llama3:70b" for better quality (requires more resources)
LLAMA_MODEL=llama3

# Ollama Server Configuration
# URL where Ollama server is running
# Default: "http://localhost:11434"
# Change if Ollama is running on a different host or port
LLAMA_BASE_URL=http://localhost:11434

# Response Length Configuration
# Maximum number of tokens in LLaMA response
# Typical range: 300-800 tokens
# Default: 500
# Increase for more detailed summaries, decrease for shorter summaries
LLAMA_MAX_TOKENS=500

# Temperature Configuration
# Controls randomness in LLaMA responses
# Range: 0.0 (deterministic) to 2.0 (very creative)
# Default: 0.3
# Lower values (0.1-0.3) recommended for consistent meeting summaries
LLAMA_TEMPERATURE=0.3

# Fallback Configuration
# Enable automatic fallback to regex-based summarization when LLaMA fails
# Valid values: "true" or "false"
# Default: "true"
# Set to "false" to propagate LLaMA errors as HTTP 503 responses
LLAMA_ENABLE_FALLBACK=true

# Input Length Configuration
# Maximum length of meeting transcript in characters
# Default: 50000
# LLaMA 3 can handle long inputs, but processing time increases with length
LLAMA_MAX_TRANSCRIPT_CHARS=50000

# Request Timeout Configuration
# Maximum time in seconds to wait for LLaMA response
# Default: 120
# LLaMA can be slower than cloud APIs, especially on CPU
# Increase if you experience timeout errors with long transcripts
LLAMA_REQUEST_TIMEOUT=120

# Retry Configuration
# Maximum number of retry attempts for failed LLaMA API calls
# Default: 3
# Helps handle temporary Ollama server issues
LLAMA_MAX_RETRIES=3